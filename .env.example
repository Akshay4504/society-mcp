# ==============================================================================
# Society Maintenance Management System - Production Environment Configuration
# ==============================================================================

# General
NODE_ENV=production
NGINX_PORT=80

# Backend Service
PORT=5000
JWT_SECRET=super_secret_jwt_key_for_society_app

# MCP SSE Server Service
MCP_PORT=3001
# Optional: OpenAI API Key for AI integrations (triage/translation)
# OPENAI_API_KEY=your_openai_key_here

# MongoDB Configuration
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=super_secure_mongodb_root_password_here
MONGO_DB_NAME=society_maintenance_db
